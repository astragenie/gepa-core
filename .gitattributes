# Force LF line endings for source and config — Biome formatter expects LF
# and Windows autocrlf=true would otherwise re-convert on checkout/commit.
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf
.gitignore  text eol=lf
.npmrc      text eol=lf
